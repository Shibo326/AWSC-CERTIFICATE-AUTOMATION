{
  "enabled": true,
  "name": "Lint Python on Save",
  "description": "Runs ruff linter on edited Python files to enforce PEP 8 and project coding standards automatically.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "python -m ruff check --fix"
  }
}