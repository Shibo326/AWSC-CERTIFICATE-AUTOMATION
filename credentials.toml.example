# CertFlow Email Credentials
# Copy this file to credentials.toml and fill in your real credentials
# NEVER commit credentials.toml to git!
#
# Alternative locations (checked in order):
#   1. ./credentials.toml (next to the app)
#   2. ~/.certflow/credentials.toml (home directory)
#   3. Environment variables: CERTFLOW_EMAIL_SENDER, CERTFLOW_EMAIL_APP_PASSWORD

[email]
sender = "your-email@gmail.com"
app_password = "xxxx xxxx xxxx xxxx"
